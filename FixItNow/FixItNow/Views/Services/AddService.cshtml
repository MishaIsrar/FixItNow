@{
    Layout = "_Layout1";
    ViewData["Title"] = "Add Service";
}

<section class="app-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="app-card p-4 p-lg-5">
                    <span class="eyebrow">Provider Tools</span>
                    <h1 class="fw-bold mt-2 mb-3">Add a new service</h1>
                    <p class="lead-muted mb-4">Create a clear listing with a good title, useful details, and a representative image.</p>

                    @if (!string.IsNullOrWhiteSpace(ViewBag.ErrorMessage))
                    {
                        <div class="alert alert-danger" role="alert">@ViewBag.ErrorMessage</div>
                    }

                    <form method="post" asp-action="AddService" asp-controller="Services" enctype="multipart/form-data" id="serviceform">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="serviceTitle" class="form-label">Service title</label>
                                <input type="text" class="form-control" name="title" id="serviceTitle" placeholder="Example: Emergency plumbing repair" required>
                            </div>
                            <div class="col-md-6">
                                <label for="serviceProvider" class="form-label">Provider display name</label>
                                <input type="text" class="form-control" name="provider" id="serviceProvider" placeholder="Your name or business">
                            </div>
                            <div class="col-md-6">
                                <label for="category" class="form-label">Category</label>
                                <select class="form-select" name="category" id="category" required>
                                    <option value="" disabled selected>Select a category</option>
                                    <option value="Technology & IT Services">Technology & IT Services</option>
                                    <option value="Construction">Construction</option>
                                    <option value="Designing and Creativity">Designing and Creativity</option>
                                    <option value="Animation & Video Editing">Animation & Video Editing</option>
                                    <option value="Content Creation">Content Creation</option>
                                    <option value="Education & Training">Education & Training</option>
                                    <option value="Business & Administrative Services">Business & Administrative Services</option>
                                    <option value="Digital Marketing">Digital Marketing</option>
                                    <option value="Healthcare & Wellness">Healthcare & Wellness</option>
                                    <option value="Legal & Financial Services">Legal & Financial Services</option>
                                    <option value="Home & Lifestyle Services">Home & Lifestyle Services</option>
                                    <option value="Repair & Maintenance">Repair & Maintenance</option>
                                    <option value="Logistics & Delivery">Logistics & Delivery</option>
                                    <option value="Entertainment & Leisure">Entertainment & Leisure</option>
                                    <option value="Freelance & Gig Services">Freelance & Gig Services</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="servicePricing" class="form-label">Pricing</label>
                                <input type="number" class="form-control" name="price" id="servicePricing" placeholder="Enter starting price" min="1" step="0.01" required>
                            </div>
                            <div class="col-12">
                                <label for="serviceDescription" class="form-label">Service description</label>
                                <textarea class="form-control" name="description" id="serviceDescription" rows="5" placeholder="Describe what customers get, what is included, and any limits." required></textarea>
                            </div>
                            <div class="col-12">
                                <label for="serviceFeatures" class="form-label">Features</label>
                                <textarea class="form-control" name="features" id="serviceFeatures" rows="3" placeholder="List key features separated by commas"></textarea>
                            </div>
                            <div class="col-12">
                                <label for="serviceImage" class="form-label">Service image</label>
                                <input type="file" class="form-control" name="serviceImage" id="serviceImage" accept=".jpg,.jpeg,.png,.webp">
                            </div>
                        </div>
                        <div class="d-flex justify-content-end mt-4">
                            <button type="submit" class="btn btn-primary px-4">Add service</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
