@{
    Layout = "_Layout1";
    ViewData["Title"] = "Services";
}
@model List<Service>

<section class="app-section">
    <div class="container">
        <div class="app-page-header text-center">
            <span class="eyebrow">Marketplace</span>
            <h1 class="fw-bold mt-2 mb-2">Available services</h1>
            <p class="lead-muted mb-0">Search, filter, and compare providers before booking.</p>
        </div>

        <div class="app-card p-3 p-md-4 mb-4">
            <div class="row g-3 align-items-center">
                <div class="col-lg-7">
                    <div class="input-group">
                        <input type="text" id="searchInput" class="form-control" placeholder="Search for a service...">
                        <button id="searchButton" class="btn btn-primary">Search</button>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="d-flex flex-column flex-sm-row gap-2 justify-content-lg-end">
                        <button class="btn btn-outline-primary" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasLeft" aria-controls="offcanvasLeft">Categories</button>
                        <a href="/Services/SortByPricing" class="btn btn-outline-primary">Sort by price</a>
                    </div>
                </div>
            </div>
            <div id="searchResults" class="mt-4"></div>
        </div>

        <div class="offcanvas offcanvas-start" tabindex="-1" id="offcanvasLeft" aria-labelledby="offcanvasLeftLabel">
            <div class="offcanvas-header">
                <h5 class="offcanvas-title fw-bold" id="offcanvasLeftLabel">Categories</h5>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body">
                <div class="d-grid gap-2">
                    @foreach (var item in new Dictionary<int, string> {
                        {1, "Construction"}, {2, "Content Creation"}, {3, "Technology & IT Services"}, {4, "Designing and Creativity"},
                        {5, "Animation & Video Editing"}, {6, "Education & Training"}, {7, "Business & Administrative Services"},
                        {8, "Healthcare & Wellness"}, {9, "Legal & Financial Services"}, {10, "Home & Lifestyle Services"},
                        {11, "Repair & Maintenance"}, {12, "Logistics & Delivery"}, {13, "Entertainment & Leisure"},
                        {14, "Freelance & Gig Services"}, {15, "Digital Marketing"}
                    })
                    {
                        <a href="/Services/FilteredView/@item.Key" class="btn btn-outline-primary text-start">@item.Value</a>
                    }
                </div>
            </div>
        </div>

        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                @foreach (var service in Model)
                {
                    <div class="col-sm-6 col-lg-4">
                        <div class="card service-card">
                            <img src="/@service.referenceImagePath" class="card-img-top" alt="@service.title">
                            <div class="card-body">
                                <h5 class="card-title fw-bold">@service.title</h5>
                                <p class="lead-muted mb-2">Provider: @service.provider</p>
                                <p class="fw-bold mb-3">Starting price: @service.pricing</p>
                                <a href="/Services/ServiceDetails/@service.id" class="btn btn-primary w-100">View details</a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12"><div class="empty-state">No services available yet.</div></div>
            }
        </div>
    </div>
</section>

<section class="app-section bg-white">
    <div class="container">
        <div class="text-center mb-5">
            <span class="eyebrow">Marketplace help</span>
            <h2 class="fw-bold mt-2">How to choose a service</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4"><div class="app-card step-card lift-3d"><span class="step-number">1</span><h5 class="fw-bold mt-3">Compare details</h5><p class="lead-muted mb-0">Review provider name, starting price, category, and included features.</p></div></div>
            <div class="col-md-4"><div class="app-card step-card lift-3d"><span class="step-number">2</span><h5 class="fw-bold mt-3">Ask first</h5><p class="lead-muted mb-0">Use messaging if the job needs explanation before booking.</p></div></div>
            <div class="col-md-4"><div class="app-card step-card lift-3d"><span class="step-number">3</span><h5 class="fw-bold mt-3">Book clearly</h5><p class="lead-muted mb-0">Add date, time, location, and task details for smoother service.</p></div></div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/newFile.1.js"></script>
}
