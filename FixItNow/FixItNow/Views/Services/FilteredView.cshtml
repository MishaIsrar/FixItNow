@{
    Layout = "_Layout1";
    ViewData["Title"] = "Filtered Services";
}
@model List<Service>

<section class="app-section">
    <div class="container">
        <div class="app-page-header d-flex flex-column flex-lg-row justify-content-between gap-3">
            <div>
                <span class="eyebrow">Filtered Results</span>
                <h1 class="fw-bold mt-2 mb-2">Matching services</h1>
                <p class="lead-muted mb-0">Browse providers in the selected category.</p>
            </div>
            <div class="align-self-lg-end">
                <a href="/Services/Index" class="btn btn-outline-primary">All services</a>
            </div>
        </div>

        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                @foreach (var service in Model)
                {
                    <div class="col-sm-6 col-lg-4">
                        <div class="card service-card">
                            <img src="/@service.referenceImagePath" class="card-img-top" alt="@service.title">
                            <div class="card-body">
                                <h5 class="card-title fw-bold">@service.title</h5>
                                <p class="lead-muted mb-2">Provider: @service.provider</p>
                                <p class="fw-bold mb-3">Starting price: @service.pricing</p>
                                <a href="/Services/ServiceDetails/@service.id" class="btn btn-primary w-100">View details</a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12"><div class="empty-state">No services found for this category.</div></div>
            }
        </div>
    </div>
</section>
