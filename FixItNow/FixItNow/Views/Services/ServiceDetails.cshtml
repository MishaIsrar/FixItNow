@model FixItNow.Models.ViewModel.ServicesDetails
@{
    Layout = "_Layout1";
    ViewData["Title"] = "Service Details";
    var reviewTotal = Math.Max(Model.totalReviews, 1);
}

<section class="app-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="app-card overflow-hidden">
                    <img src="/@Model.service.referenceImagePath" alt="@Model.service.title" class="w-100" style="height: 340px; object-fit: cover;">
                    <div class="p-4 p-lg-5">
                        <span class="eyebrow">@Model.service.category</span>
                        <h1 class="fw-bold mt-2 mb-2">@Model.service.title</h1>
                        <p class="h4 text-primary fw-bold mb-3">Starting from @Model.service.pricing</p>
                        <p class="lead-muted mb-4">@Model.service.description</p>

                        <div class="p-3 border rounded mb-4">
                            <strong>Provider:</strong> @Model.service.provider
                            <a href="/Provider/Index/@Model.service.providerID" class="ms-2">View profile</a>
                        </div>

                        @if (Model.service.features != null && Model.service.features.Any())
                        {
                            <h5 class="fw-bold">What you will get</h5>
                            <div class="row g-2 mb-4">
                                @foreach (var feature in Model.service.features)
                                {
                                    <div class="col-sm-6">
                                        <div class="p-2 rounded bg-light"><i class="bi bi-check-circle text-success me-2"></i>@feature</div>
                                    </div>
                                }
                            </div>
                        }

                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-primary" href="/Booking/Index/@Model.service.id">Book now</a>
                            <a class="btn btn-outline-primary" href="/Message/Index/@Model.service.id">Message provider</a>
                            <a class="btn btn-outline-primary" href="/Services/Save/@Model.service.id">Save service</a>
                        </div>
                    </div>
                </div>

                <div class="app-card p-4 mt-4">
                    <h4 class="fw-bold mb-3">@Model.totalReviews Reviews</h4>
                    @foreach (var row in new[] {
                        ("5 Stars", Model.fiveStar), ("4 Stars", Model.fourStar), ("3 Stars", Model.threeStar), ("2 Stars", Model.twoStar), ("1 Star", Model.oneStar)
                    })
                    {
                        <div class="row align-items-center mb-2">
                            <div class="col-3 col-md-2">@row.Item1</div>
                            <div class="col-7 col-md-8">
                                <div class="progress">
                                    <div class="progress-bar" role="progressbar" style="width: @((row.Item2 / (float)reviewTotal) * 100)%;" aria-valuenow="@row.Item2" aria-valuemin="0" aria-valuemax="@reviewTotal"></div>
                                </div>
                            </div>
                            <div class="col-2 text-end">@row.Item2</div>
                        </div>
                    }
                </div>

                <div class="app-card p-4 mt-4">
                    <h4 class="fw-bold mb-3">Customer reviews</h4>
                    @if (Model.Reviews != null && Model.Reviews.Any())
                    {
                        <div class="d-grid gap-3">
                            @foreach (var review in Model.Reviews)
                            {
                                <div class="p-3 border rounded">
                                    <div class="d-flex align-items-center gap-3 mb-2">
                                        <img src="/images/image.png" alt="@review.name" width="42" height="42" class="rounded-circle">
                                        <div>
                                            <strong>@review.name</strong>
                                            <div class="text-warning">
                                                @for (int i = 0; i < review.rating; i++)
                                                {
                                                    <span>★</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                    <p class="lead-muted mb-0">@review.comments</p>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">No reviews yet.</div>
                    }
                </div>
            </div>

            <div class="col-lg-4">
                <div class="app-card p-4">
                    <h4 class="fw-bold mb-3">Related services</h4>
                    @if (Model.RelatedServices != null && Model.RelatedServices.Any())
                    {
                        <div class="d-grid gap-3">
                            @foreach (var service in Model.RelatedServices)
                            {
                                <a class="d-flex gap-3 align-items-center p-2 border rounded" href="/Services/ServiceDetails/@service.id">
                                    <img src="/@service.referenceImagePath" alt="@service.title" width="64" height="64" class="rounded" style="object-fit: cover;">
                                    <div>
                                        <strong>@service.title</strong>
                                        <div class="text-muted">Starting at @service.pricing</div>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="lead-muted mb-0">No related services yet.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
