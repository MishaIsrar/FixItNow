@{
    Layout = "_Layout1";
    ViewData["Title"] = "My Bookings";
}
@model FixItNow.Models.ViewModel.UserCart

<section class="app-section">
    <div class="container">
        <div class="app-page-header">
            <span class="eyebrow">Customer Workspace</span>
            <h1 class="fw-bold mt-2 mb-2">My bookings and saved services</h1>
            <p class="lead-muted mb-0">Review your booking history and quickly return to saved services.</p>
        </div>

        <div class="app-card mb-4">
            <div class="card-body">
                <h4 class="fw-bold mb-3">Past bookings</h4>
                @if (Model.Bookings != null && Model.Bookings.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Booking</th>
                                    <th>Service</th>
                                    <th>Date</th>
                                    <th>Spending</th>
                                    <th>Review</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.Bookings.Count; i++)
                                {
                                    <tr>
                                        <td>@Model.Bookings[i].Id</td>
                                        <td>@Model.Bookings[i].serviceId</td>
                                        <td>@Model.Bookings[i].Date.ToString("dd MMM yyyy")</td>
                                        <td>@Model.Bookings[i].pricing</td>
                                        <td>
                                            @if (Model.exists != null && i < Model.exists.Count && Model.exists[i] == 1)
                                            {
                                                <span class="badge text-bg-success">Review done</span>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-primary" onclick="openReviewForm(@Model.Bookings[i].serviceId)">Add review</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">No bookings yet.</div>
                }
            </div>
        </div>

        <div class="app-card">
            <div class="card-body">
                <h4 class="fw-bold mb-3">Saved services</h4>
                @if (Model.SavedServices != null && Model.SavedServices.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Service</th>
                                    <th>Name</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.SavedServices.Count; i++)
                                {
                                    <tr>
                                        <td>@(i + 1)</td>
                                        <td>@Model.SavedServices[i].serviceId</td>
                                        <td>@Model.SavedServices[i].serviceName</td>
                                        <td class="text-end">
                                            <a href="/Booking/Index/@Model.SavedServices[i].serviceId" class="btn btn-sm btn-primary">Book</a>
                                            <a href="/Services/RemoveFromSaved/@Model.SavedServices[i].id" class="btn btn-sm btn-outline-danger">Remove</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">No saved services yet.</div>
                }
            </div>
        </div>
    </div>
</section>

<div id="reviewForm" style="display: none;">
    @Html.Partial("_ReviewForm")
</div>

@section Scripts {
    <script>
        function openReviewForm(serviceId) {
            const reviewForm = document.getElementById('reviewForm');
            const serviceInput = document.getElementById('serviceid');
            if (serviceInput) {
                serviceInput.value = serviceId;
            }
            reviewForm.style.display = 'block';
        }
    </script>
}
