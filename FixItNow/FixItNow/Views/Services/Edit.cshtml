@{
    Layout = "_Layout1";
    ViewData["Title"] = "Edit Service";
}
@model Service

<section class="app-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="app-card p-4 p-lg-5">
                    <span class="eyebrow">Provider Tools</span>
                    <h1 class="fw-bold mt-2 mb-4">Edit service</h1>
                    <form method="post" asp-action="Edit" asp-controller="Services">
                        <div class="mb-3">
                            <label for="serviceTitle" class="form-label">Service title</label>
                            <input type="text" class="form-control" name="Title" id="serviceTitle" value="@Model.title" required>
                        </div>
                        <div class="mb-3">
                            <label for="serviceDescription" class="form-label">Service description</label>
                            <textarea class="form-control" name="Description" id="serviceDescription" rows="5" required>@Model.description</textarea>
                        </div>
                        <div class="mb-4">
                            <label for="servicePricing" class="form-label">Pricing</label>
                            <input type="number" class="form-control" name="Price" id="servicePricing" value="@Model.pricing" min="1" step="0.01" required>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <button type="submit" class="btn btn-primary">Save changes</button>
                            <a href="/Provider/ProviderPanel" class="btn btn-outline-primary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
