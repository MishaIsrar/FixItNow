@{
    Layout = "_Layout1";
    ViewData["Title"] = "Message";
}
@model Messages

<section class="app-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="app-card p-4 p-lg-5">
                    <span class="eyebrow">Message</span>
                    <h1 class="fw-bold mt-2 mb-4">@Model.title</h1>
                    <dl class="row mb-4">
                        <dt class="col-sm-3 text-muted">From</dt>
                        <dd class="col-sm-9">@Model.senderName</dd>
                        <dt class="col-sm-3 text-muted">Date</dt>
                        <dd class="col-sm-9">@Model.DateTime</dd>
                        <dt class="col-sm-3 text-muted">Service</dt>
                        <dd class="col-sm-9">@Model.serviceName</dd>
                    </dl>
                    <div class="p-4 rounded border bg-light mb-4">
                        @Model.message
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <a href="/Message/Index/@Model.serviceId" class="btn btn-primary">Reply</a>
                        <a href="/Message/Inbox" class="btn btn-outline-primary">Back to inbox</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
