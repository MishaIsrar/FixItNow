@{
    Layout = "_Layout1";
    ViewData["Title"] = "Inbox";
}
@model List<Messages>

<section class="app-section">
    <div class="container">
        <div class="app-page-header">
            <span class="eyebrow">Messages</span>
            <h1 class="fw-bold mt-2 mb-2">Inbox</h1>
            <p class="lead-muted mb-0">Track customer and provider conversations in one place.</p>
        </div>

        <div class="app-card">
            <div class="card-body p-0">
                @if (Model != null && Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Sender</th>
                                    <th>Service</th>
                                    <th>Subject</th>
                                    <th>Date</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var message in Model)
                                {
                                    <tr>
                                        <td>@message.senderName</td>
                                        <td><span class="badge text-bg-light">@message.serviceName</span></td>
                                        <td>@message.title</td>
                                        <td class="text-muted">@message.DateTime</td>
                                        <td class="text-end">
                                            <a class="btn btn-sm btn-outline-primary" href="/Message/Read/@message.Id">Read</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state m-4">No messages yet.</div>
                }
            </div>
        </div>
    </div>
</section>
