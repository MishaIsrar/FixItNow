@{
    Layout = "_Layout1";
    ViewData["Title"] = "Contact Provider";
}

<section class="app-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="app-card p-4 p-lg-5">
                    <span class="eyebrow">Provider Message</span>
                    <h1 class="fw-bold mt-2 mb-3">Contact provider</h1>
                    <p class="lead-muted mb-4">Ask a question before booking or share extra context about your service request.</p>

                    @if (!string.IsNullOrWhiteSpace(ViewBag.Error))
                    {
                        <div class="alert alert-danger" role="alert">@ViewBag.Error</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(ViewBag.Sent))
                    {
                        <div class="alert alert-success" role="alert">@ViewBag.Sent</div>
                    }

                    <form method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label for="from" class="form-label">From</label>
                            <input type="text" id="from" name="from" class="form-control" placeholder="Your name or email" required>
                        </div>
                        <div class="mb-3">
                            <label for="messagetitle" class="form-label">Subject</label>
                            <input type="text" id="messagetitle" name="messagetitle" class="form-control" placeholder="What is your message about?" required>
                        </div>
                        <div class="mb-4">
                            <label for="message" class="form-label">Message</label>
                            <textarea id="message" name="message" rows="6" class="form-control" placeholder="Write your message here..." required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary px-4">Send message</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
