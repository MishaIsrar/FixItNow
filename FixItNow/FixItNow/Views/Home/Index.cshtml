@model List<Review>
@{
    Layout = "_Layout1";
    ViewData["Title"] = "Home";
    var testimonials = Model?.Take(3).ToList() ?? new List<Review>();
}

<section class="app-section" style="background: linear-gradient(135deg, #dae9f5, #fff1ec);">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 reveal-up">
                <span class="eyebrow">Local service booking</span>
                <h1 class="display-5 fw-bold mt-3 mb-3">Find reliable help for the work that cannot wait.</h1>
                <p class="lead lead-muted mb-4">Book skilled providers for home repairs, maintenance, professional tasks, and everyday services with clear pricing, reviews, and direct messaging.</p>
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-primary px-4" href="/Services/Index">Browse services</a>
                    <a class="btn btn-accent px-4" href="/Authentication/ProviderRegistration">Become a provider</a>
                </div>
            </div>
            <div class="col-lg-6 reveal-up-delay-1">
                <img src="/images/svg1.svg" alt="Service professionals" class="img-fluid float-soft">
            </div>
        </div>
    </div>
</section>

<section class="metric-strip py-4">
    <div class="container">
        <div class="row g-3 text-center">
            <div class="col-6 col-lg-3"><div class="fw-bold h3 mb-0">15+</div><div class="lead-muted">Service categories</div></div>
            <div class="col-6 col-lg-3"><div class="fw-bold h3 mb-0">24/7</div><div class="lead-muted">Online requests</div></div>
            <div class="col-6 col-lg-3"><div class="fw-bold h3 mb-0">3-step</div><div class="lead-muted">Booking flow</div></div>
            <div class="col-6 col-lg-3"><div class="fw-bold h3 mb-0">Direct</div><div class="lead-muted">Provider messaging</div></div>
        </div>
    </div>
</section>

<section class="app-section">
    <div class="container">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="stat-tile h-100 reveal-up">
                    <div class="h4 fw-bold">Verified providers</div>
                    <p class="lead-muted mb-0">Admins review provider registrations before they can publish services.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-tile h-100 reveal-up-delay-1">
                    <div class="h4 fw-bold">Simple booking</div>
                    <p class="lead-muted mb-0">Share task details, date, budget, and address from one focused booking form.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-tile h-100 reveal-up-delay-2">
                    <div class="h4 fw-bold">Direct messaging</div>
                    <p class="lead-muted mb-0">Ask providers questions before booking and keep service communication in one inbox.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="app-section feature-band">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-lg-5">
                <span class="eyebrow text-white-50">How it works</span>
                <h2 class="fw-bold mt-2">From search to service without the confusion.</h2>
                <p class="lead-muted mb-0">FixItNow keeps discovery, messaging, booking, and reviews connected so every service request has context.</p>
            </div>
            <div class="col-lg-7">
                <div class="row g-3">
                    <div class="col-md-4"><div class="app-card step-card lift-3d"><span class="step-number">1</span><h5 class="fw-bold mt-3">Find</h5><p class="lead-muted mb-0">Search categories and compare providers.</p></div></div>
                    <div class="col-md-4"><div class="app-card step-card lift-3d"><span class="step-number">2</span><h5 class="fw-bold mt-3">Discuss</h5><p class="lead-muted mb-0">Message providers before booking.</p></div></div>
                    <div class="col-md-4"><div class="app-card step-card lift-3d"><span class="step-number">3</span><h5 class="fw-bold mt-3">Book</h5><p class="lead-muted mb-0">Confirm date, budget, and location.</p></div></div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="app-section bg-white">
    <div class="container">
        <div class="text-center mb-5">
            <span class="eyebrow">Popular categories</span>
            <h2 class="fw-bold mt-2">Services for home and work</h2>
        </div>
        <div class="row g-4">
            <div class="col-sm-6 col-lg-4">
                <div class="app-card p-4 h-100">
                    <i class="bi bi-tools h2 text-primary"></i>
                    <h5 class="fw-bold mt-3">Repair & Maintenance</h5>
                    <p class="lead-muted mb-0">Appliance fixes, furniture repairs, electrical help, plumbing, and routine maintenance.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4">
                <div class="app-card p-4 h-100">
                    <i class="bi bi-house-check h2 text-primary"></i>
                    <h5 class="fw-bold mt-3">Home & Lifestyle</h5>
                    <p class="lead-muted mb-0">Cleaning, gardening, interior help, household support, and property services.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4">
                <div class="app-card p-4 h-100">
                    <i class="bi bi-laptop h2 text-primary"></i>
                    <h5 class="fw-bold mt-3">Technology & IT</h5>
                    <p class="lead-muted mb-0">Development, digital support, technical troubleshooting, and creative services.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="app-section bg-white">
    <div class="container">
        <div class="text-center mb-5">
            <span class="eyebrow">Why customers use it</span>
            <h2 class="fw-bold mt-2">Built for repeated, everyday service needs</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3"><div class="app-card p-4 h-100 lift-3d"><i class="bi bi-search h3 text-primary"></i><h5 class="fw-bold mt-3">Fast discovery</h5><p class="lead-muted mb-0">Browse broad categories without calling around manually.</p></div></div>
            <div class="col-md-6 col-lg-3"><div class="app-card p-4 h-100 lift-3d"><i class="bi bi-chat-dots h3 text-primary"></i><h5 class="fw-bold mt-3">Clear context</h5><p class="lead-muted mb-0">Ask questions before you commit to a booking.</p></div></div>
            <div class="col-md-6 col-lg-3"><div class="app-card p-4 h-100 lift-3d"><i class="bi bi-calendar2-check h3 text-primary"></i><h5 class="fw-bold mt-3">Organized bookings</h5><p class="lead-muted mb-0">Keep booking history and saved services together.</p></div></div>
            <div class="col-md-6 col-lg-3"><div class="app-card p-4 h-100 lift-3d"><i class="bi bi-star h3 text-primary"></i><h5 class="fw-bold mt-3">Review loop</h5><p class="lead-muted mb-0">Share feedback after completed work.</p></div></div>
        </div>
    </div>
</section>

<section class="app-section">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-5">
                <span class="eyebrow">Customer feedback</span>
                <h2 class="fw-bold mt-2">What people say</h2>
                <p class="lead-muted">Reviews help customers compare providers and help good providers stand out.</p>
            </div>
            <div class="col-lg-7">
                <div id="testimonialCarousel" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        @if (testimonials.Any())
                        {
                            for (var i = 0; i < testimonials.Count; i++)
                            {
                                <div class="carousel-item @(i == 0 ? "active" : "")">
                                    <div class="app-card p-4">
                                        <p class="lead-muted mb-4">@testimonials[i].comments</p>
                                        <div class="d-flex align-items-center gap-3">
                                            <img src="/images/image.png" alt="Customer" width="48" height="48" class="rounded-circle">
                                            <strong>@testimonials[i].name</strong>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="carousel-item active">
                                <div class="app-card p-4">
                                    <p class="lead-muted mb-4">Trusted local service providers are ready to help with your next task.</p>
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="/images/image.png" alt="FixItNow" width="48" height="48" class="rounded-circle">
                                        <strong>FixItNow</strong>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
