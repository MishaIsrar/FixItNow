@{
    Layout = "_Layout1";
    ViewData["Title"] = "FAQs";
}

<section class="app-section">
    <div class="container">
        <div class="app-page-header text-center">
            <span class="eyebrow">Support</span>
            <h1 class="fw-bold mt-2 mb-2">Frequently asked questions</h1>
            <p class="lead-muted mb-0">Quick answers about booking, providers, payments, and account workflows.</p>
        </div>
        <div class="row g-4">
            @foreach (var faq in new[] {
                ("What types of services do you offer?", "Home maintenance, technical support, IT services, creative work, business help, and lifestyle assistance."),
                ("How quickly can I book a service?", "You can submit a booking request immediately. Providers can then review the task details and coordinate timing."),
                ("Are service providers qualified?", "Providers submit profile and credential details, and admins approve provider accounts before they can manage services."),
                ("What payment options are supported?", "The current workflow records booking price details. Payment processing can be connected during the next production phase."),
                ("Can I message a provider first?", "Yes. Each service detail page lets customers contact the provider before booking."),
                ("Can I reschedule or cancel a booking?", "You should message the provider as early as possible. A formal cancellation workflow can be added as a future enhancement.")
            })
            {
                <div class="col-md-6 col-lg-4">
                    <div class="app-card p-4 h-100">
                        <h5 class="fw-bold">@faq.Item1</h5>
                        <p class="lead-muted mb-0">@faq.Item2</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
