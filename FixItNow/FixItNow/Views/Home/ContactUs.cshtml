@{
    Layout = "_Layout1";
    ViewData["Title"] = "Contact";
}

<section class="app-section">
    <div class="container">
        <div class="row g-4 align-items-start">
            <div class="col-lg-5">
                <span class="eyebrow">Contact</span>
                <h1 class="fw-bold mt-2 mb-3">Get in touch</h1>
                <p class="lead-muted mb-4">Questions about booking, providers, or platform support? Send a message and the team will get back to you.</p>
                <div class="d-grid gap-3">
                    <div class="stat-tile">
                        <h5 class="fw-bold">Address</h5>
                        <p class="lead-muted mb-0">Mall Road, Lahore, Punjab, Pakistan</p>
                    </div>
                    <div class="stat-tile">
                        <h5 class="fw-bold">Phone</h5>
                        <p class="lead-muted mb-0"><a href="tel:+923403040319">+92 340 3040319</a></p>
                    </div>
                    <div class="stat-tile">
                        <h5 class="fw-bold">Email</h5>
                        <p class="lead-muted mb-0"><a href="mailto:contact@fixitnow.com">contact@fixitnow.com</a></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="app-card p-4 p-lg-5">
                    <form action="#!">
                        <div class="row g-3">
                            <div class="col-12">
                                <label for="fullname" class="form-label">Full name</label>
                                <input type="text" class="form-control" id="fullname" name="fullname" required>
                            </div>
                            <div class="col-md-6">
                                <label for="email" class="form-label">Email</label>
                                <input type="email" class="form-control" id="email" name="email" required>
                            </div>
                            <div class="col-md-6">
                                <label for="phone" class="form-label">Phone</label>
                                <input type="tel" class="form-control" id="phone" name="phone">
                            </div>
                            <div class="col-12">
                                <label for="subject" class="form-label">Subject</label>
                                <input type="text" class="form-control" id="subject" name="subject" required>
                            </div>
                            <div class="col-12">
                                <label for="message" class="form-label">Message</label>
                                <textarea class="form-control" id="message" name="message" rows="6" required></textarea>
                            </div>
                        </div>
                        <div class="d-flex justify-content-end mt-4">
                            <button class="btn btn-primary px-4" type="submit">Send message</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="app-section bg-white">
    <div class="container">
        <div class="text-center mb-5">
            <span class="eyebrow">Support paths</span>
            <h2 class="fw-bold mt-2">Choose the right place to start</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4"><div class="app-card p-4 h-100 lift-3d"><h5 class="fw-bold">Need a service?</h5><p class="lead-muted">Browse the marketplace and book directly from service details.</p><a href="/Services/Index" class="btn btn-outline-primary">Browse services</a></div></div>
            <div class="col-md-4"><div class="app-card p-4 h-100 lift-3d"><h5 class="fw-bold">Provider question?</h5><p class="lead-muted">Register as a provider and wait for admin approval before publishing.</p><a href="/Authentication/ProviderRegistration" class="btn btn-outline-primary">Join as provider</a></div></div>
            <div class="col-md-4"><div class="app-card p-4 h-100 lift-3d"><h5 class="fw-bold">Common issue?</h5><p class="lead-muted">Check frequently asked questions about bookings and account flows.</p><a href="/Home/FAQS" class="btn btn-outline-primary">Read FAQs</a></div></div>
        </div>
    </div>
</section>
