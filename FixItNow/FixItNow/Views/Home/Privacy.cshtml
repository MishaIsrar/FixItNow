@{
    Layout = "_Layout1";
    ViewData["Title"] = "Privacy";
}

<section class="app-section">
    <div class="container">
        <div class="app-page-header text-center">
            <span class="eyebrow">Privacy</span>
            <h1 class="fw-bold mt-2 mb-2">Privacy Policy</h1>
            <p class="lead-muted mb-0">Effective Date: January 1, 2024</p>
        </div>
        <div class="app-card p-4 p-lg-5">
            <div class="d-grid gap-4">
                <section>
                    <h4 class="fw-bold">Introduction</h4>
                    <p class="lead-muted mb-0">Your privacy is important to us. This policy explains how FixItNow collects, uses, discloses, and safeguards information when you use the platform.</p>
                </section>
                <section>
                    <h4 class="fw-bold">Information We Collect</h4>
                    <ul class="lead-muted mb-0">
                        <li>Personal identification information such as name, email, and phone number.</li>
                        <li>Service and booking information submitted through the platform.</li>
                        <li>Basic usage data used to improve reliability and user experience.</li>
                    </ul>
                </section>
                <section>
                    <h4 class="fw-bold">How We Use Information</h4>
                    <ul class="lead-muted mb-0">
                        <li>To provide and improve booking, messaging, and provider management services.</li>
                        <li>To communicate about accounts, bookings, and support requests.</li>
                        <li>To maintain platform safety and prevent misuse.</li>
                    </ul>
                </section>
                <section>
                    <h4 class="fw-bold">Data Protection</h4>
                    <p class="lead-muted mb-0">We use reasonable security measures to protect data, though no internet transmission or storage method can be guaranteed completely secure.</p>
                </section>
                <section>
                    <h4 class="fw-bold">Your Rights</h4>
                    <p class="lead-muted mb-0">You may request access, correction, or deletion of personal information by contacting the FixItNow team.</p>
                </section>
            </div>
        </div>
    </div>
</section>
