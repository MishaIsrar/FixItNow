@{
    Layout = "_Layout1";
    ViewData["Title"] = "About";
}

<section class="app-section" style="background: linear-gradient(135deg, rgba(28,99,167,.92), rgba(10,75,120,.86)), url('/images/newbg.jpg') center/cover;">
    <div class="container text-white">
        <div class="row justify-content-center text-center">
            <div class="col-lg-9">
                <span class="eyebrow text-white-50">About FixItNow</span>
                <h1 class="display-5 fw-bold mt-3 mb-3">A simpler way to find trusted help.</h1>
                <p class="lead mb-0 text-white-50">FixItNow connects customers with skilled providers for repairs, maintenance, lifestyle support, technology work, and professional services.</p>
            </div>
        </div>
    </div>
</section>

<section class="app-section bg-white">
    <div class="container">
        <div class="text-center mb-5">
            <span class="eyebrow">What guides us</span>
            <h2 class="fw-bold mt-2">A platform built around trust and speed</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4"><div class="app-card p-4 h-100 lift-3d"><h5 class="fw-bold">Reliable profiles</h5><p class="lead-muted mb-0">Provider profiles make skills, experience, and availability easier to understand before contact.</p></div></div>
            <div class="col-md-4"><div class="app-card p-4 h-100 lift-3d"><h5 class="fw-bold">Practical workflows</h5><p class="lead-muted mb-0">Customers can move from searching to messaging to booking without switching tools.</p></div></div>
            <div class="col-md-4"><div class="app-card p-4 h-100 lift-3d"><h5 class="fw-bold">Better accountability</h5><p class="lead-muted mb-0">Reviews and admin approval flows help improve confidence in service quality.</p></div></div>
        </div>
    </div>
</section>

<section class="app-section">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-lg-6">
                <span class="eyebrow">Our Mission</span>
                <h2 class="fw-bold mt-2">Make service booking transparent and reliable.</h2>
                <p class="lead-muted">We help customers compare services, message providers, book work, and leave reviews. Providers get practical tools to publish services, manage bookings, and grow their reputation.</p>
            </div>
            <div class="col-lg-6">
                <div class="row g-3">
                    <div class="col-sm-6"><div class="stat-tile h-100"><div class="stat-value">5k+</div><div>Customer requests supported</div></div></div>
                    <div class="col-sm-6"><div class="stat-tile h-100"><div class="stat-value">4.8</div><div>Target service rating</div></div></div>
                    <div class="col-sm-6"><div class="stat-tile h-100"><div class="stat-value">15</div><div>Service categories</div></div></div>
                    <div class="col-sm-6"><div class="stat-tile h-100"><div class="stat-value">24/7</div><div>Online discovery</div></div></div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="app-section feature-band">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-5">
                <span class="eyebrow text-white-50">Platform approach</span>
                <h2 class="fw-bold mt-2">Designed for customers and providers.</h2>
            </div>
            <div class="col-lg-7">
                <div class="row g-3">
                    <div class="col-md-6"><div class="p-4 rounded bg-white text-dark h-100"><h5 class="fw-bold">For customers</h5><p class="lead-muted mb-0">Find help, save services, manage bookings, and review completed work.</p></div></div>
                    <div class="col-md-6"><div class="p-4 rounded bg-white text-dark h-100"><h5 class="fw-bold">For providers</h5><p class="lead-muted mb-0">Publish services, view bookings, answer messages, and understand performance.</p></div></div>
                </div>
            </div>
        </div>
    </div>
</section>
