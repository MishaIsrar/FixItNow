@using FixItNow.Services
@inject CurrentUserService CurrentUserService
@{
    var currentUser = await CurrentUserService.GetCurrentUserAsync();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FixItNow</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.10.5/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
    <nav class="navbar navbar-expand-lg navbar-light app-navbar">
        <div class="container">
            <a class="navbar-brand fw-bolder" href="/Home/Index">FixItNow</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto fw-bold">
                    @if (currentUser?.Type == "user")
                    {
                        <li class="nav-item"><a class="nav-link" href="/Home/Index">Home</a></li>
                    }
                    else if (currentUser?.Type == "provider")
                    {
                        <li class="nav-item"><a class="nav-link" href="/Home/Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Provider/ProviderPanel">Provider Panel</a></li>
                    }
                    else if (currentUser?.Type == "admin")
                    {
                        <li class="nav-item"><a class="nav-link" href="/Admin/Index">Admin</a></li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" href="/Home/Index">Home</a></li>
                    }

                    <li class="nav-item"><a class="nav-link" href="/Home/AboutUs">About Us</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/ContactUs">Contact Us</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Services/Index">Need A Service?</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/FAQS">FAQS</a></li>
                    @if (currentUser != null)
                    {
                        <li class="nav-item"><a class="nav-link" href="/Message/Inbox">Inbox</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Authentication/Logout">Logout</a></li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" href="/Authentication/SignIn">Sign In</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main role="main" class="app-main">
        @RenderBody()
    </main>

    <footer class="app-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="footer-brand h4 fw-bold mb-3">FixItNow</div>
                    <p class="mb-0">Reliable services, vetted providers, and simple booking tools for everyday home and professional needs.</p>
                </div>
                <div class="col-6 col-lg-2">
                    <h6 class="fw-bold mb-3">Explore</h6>
                    <ul class="list-unstyled d-grid gap-2">
                        <li><a href="/Services/Index">Services</a></li>
                        <li><a href="/Home/AboutUs">About</a></li>
                        <li><a href="/Home/FAQS">FAQs</a></li>
                        <li><a href="/Home/ContactUs">Contact</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-3">
                    <h6 class="fw-bold mb-3">Account</h6>
                    <ul class="list-unstyled d-grid gap-2">
                        <li><a href="/Authentication/SignIn">Sign in</a></li>
                        <li><a href="/Authentication/SignUp">Create account</a></li>
                        <li><a href="/Authentication/ProviderRegistration">Join as provider</a></li>
                        <li><a href="/Message/Inbox">Inbox</a></li>
                    </ul>
                </div>
                <div class="col-lg-3">
                    <h6 class="fw-bold mb-3">Contact</h6>
                    <p class="mb-2">Lahore, Punjab, Pakistan</p>
                    <p class="mb-2"><a href="mailto:contact@fixitnow.com">contact@fixitnow.com</a></p>
                    <p class="mb-0"><a href="tel:+923403040319">+92 340 3040319</a></p>
                </div>
            </div>
            <div class="footer-bottom d-flex flex-column flex-md-row justify-content-between gap-2">
                <span>&copy; @DateTime.Now.Year FixItNow. All rights reserved.</span>
                <span>Built for fast, local service booking.</span>
            </div>
        </div>
    </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
