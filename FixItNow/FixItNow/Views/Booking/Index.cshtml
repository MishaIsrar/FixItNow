@{
    Layout = "_Layout1";
    ViewData["Title"] = "Book Service";
}

<section class="app-section">
    <div class="container">
        <div class="row g-4 align-items-start">
            <div class="col-lg-7">
                <div class="app-card p-4 p-lg-5">
                    <span class="eyebrow">Booking Request</span>
                    <h1 class="fw-bold mt-2 mb-3">Book a service</h1>
                    <p class="lead-muted mb-4">Share the details, preferred date, and budget so the provider can understand the work before confirming.</p>

                    @if (!string.IsNullOrWhiteSpace(ViewBag.DateError))
                    {
                        <div class="alert alert-danger" role="alert">@ViewBag.DateError</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(ViewBag.Error))
                    {
                        <div class="alert alert-danger" role="alert">@ViewBag.Error</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(ViewBag.Confirmation))
                    {
                        <div class="alert alert-success" role="alert">@ViewBag.Confirmation</div>
                    }

                    <form asp-controller="Booking" asp-action="Index" method="post" id="booking">
                        <input type="hidden" id="id" name="id" value="@ViewBag.x" />
                        <div class="mb-3">
                            <label for="taskDetails" class="form-label">Task details</label>
                            <textarea class="form-control" id="taskDetails" name="taskDetails" rows="5" placeholder="Explain the task you need done" required></textarea>
                        </div>
                        <div class="mb-3">
                            <label for="address" class="form-label">Service address</label>
                            <textarea class="form-control" id="address" name="address" rows="2" placeholder="Where should the provider arrive?" required></textarea>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label for="pricing" class="form-label">Budget</label>
                                <input type="text" class="form-control" id="pricing" name="pricing" placeholder="Price" required>
                            </div>
                            <div class="col-md-4">
                                <label for="serviceDate" class="form-label">Preferred date</label>
                                <input type="date" class="form-control" id="serviceDate" name="serviceDate" required>
                            </div>
                            <div class="col-md-4">
                                <label for="serviceTime" class="form-label">Preferred time</label>
                                <input type="time" class="form-control" id="serviceTime" name="serviceTime" required>
                            </div>
                        </div>
                        <div class="form-check my-4">
                            <input type="checkbox" class="form-check-input" id="agreeTerms" name="agreeTerms" required>
                            <label class="form-check-label" for="agreeTerms">I agree to the booking terms and cancellation policy.</label>
                        </div>
                        <button type="submit" id="book" class="btn btn-primary px-4">Confirm booking</button>
                    </form>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="stat-tile">
                    <h4 class="fw-bold mb-3">Before you book</h4>
                    <ul class="list-unstyled d-grid gap-3 lead-muted mb-0">
                        <li>All bookings are subject to provider availability.</li>
                        <li>Cancellations should be communicated at least 24 hours in advance.</li>
                        <li>Payment is required after service completion unless agreed otherwise.</li>
                        <li>Keep your task details clear so providers can prepare properly.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="app-section bg-white">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4"><div class="app-card p-4 h-100 lift-3d"><h5 class="fw-bold">Be specific</h5><p class="lead-muted mb-0">Clear task details help providers estimate time, tools, and scope.</p></div></div>
            <div class="col-md-4"><div class="app-card p-4 h-100 lift-3d"><h5 class="fw-bold">Choose realistic timing</h5><p class="lead-muted mb-0">Pick a date and time window that gives the provider enough notice.</p></div></div>
            <div class="col-md-4"><div class="app-card p-4 h-100 lift-3d"><h5 class="fw-bold">Keep communication open</h5><p class="lead-muted mb-0">Use messaging if there are changes before the appointment.</p></div></div>
        </div>
    </div>
</section>
