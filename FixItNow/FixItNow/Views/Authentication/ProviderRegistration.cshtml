@{
    Layout = "_Layout1";
    ViewData["Title"] = "Provider Registration";
}

<section class="auth-page">
    <div class="container">
        <div class="auth-card app-card">
            <div class="row g-0">
                <div class="col-lg-4">
                    <div class="auth-side">
                        <span class="eyebrow text-white-50">Provider Onboarding</span>
                        <h1 class="mt-3">Offer your services professionally.</h1>
                        <p class="text-white-50">Create a provider profile, upload your credentials, and wait for admin approval before publishing services.</p>
                    </div>
                </div>
                <div class="col-lg-8">
                    <form class="auth-form" method="post" enctype="multipart/form-data" asp-controller="Authentication" asp-action="ProviderRegistration">
                        <h2 class="fw-bold mb-2">Register as a provider</h2>
                        <p class="lead-muted mb-4">Complete your profile with accurate contact and skill information.</p>

                        @if (!string.IsNullOrWhiteSpace(ViewBag.Message))
                        {
                            <div class="alert alert-danger" role="alert">@ViewBag.Message</div>
                        }
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="firstName" class="form-label">First name</label>
                                <input type="text" class="form-control" id="firstName" name="FirstName" required>
                            </div>
                            <div class="col-md-6">
                                <label for="lastName" class="form-label">Last name</label>
                                <input type="text" class="form-control" id="lastName" name="LastName" required>
                            </div>
                            <div class="col-md-6">
                                <label for="email" class="form-label">Email</label>
                                <input type="email" class="form-control" id="email" name="Email" autocomplete="email" required>
                            </div>
                            <div class="col-md-6">
                                <label for="phone" class="form-label">Phone number</label>
                                <input type="tel" class="form-control" id="phone" name="Phone" required>
                            </div>
                            <div class="col-md-6">
                                <label for="password" class="form-label">Password</label>
                                <input type="password" class="form-control" id="password" name="Password" autocomplete="new-password" required>
                            </div>
                            <div class="col-md-6">
                                <label for="retypePassword" class="form-label">Retype password</label>
                                <input type="password" class="form-control" id="retypePassword" name="RetypePassword" autocomplete="new-password" required>
                            </div>
                            <div class="col-md-12">
                                <label for="address" class="form-label">Address</label>
                                <input type="text" class="form-control" id="address" name="Address" required>
                            </div>
                            <div class="col-md-6">
                                <label for="city" class="form-label">City</label>
                                <input type="text" class="form-control" id="city" name="City" required>
                            </div>
                            <div class="col-md-6">
                                <label for="province" class="form-label">Province</label>
                                <input type="text" class="form-control" id="province" name="Province" required>
                            </div>
                            <div class="col-md-6">
                                <label for="cnic" class="form-label">CNIC</label>
                                <input type="text" class="form-control" id="cnic" name="CNIC" required>
                            </div>
                            <div class="col-md-6">
                                <label for="education" class="form-label">Education</label>
                                <input type="text" class="form-control" id="education" name="Education">
                            </div>
                            <div class="col-md-6">
                                <label for="skill" class="form-label">Primary skill</label>
                                <input type="text" class="form-control" id="skill" name="skill" required>
                            </div>
                            <div class="col-md-6">
                                <label for="experience" class="form-label">Experience</label>
                                <input type="text" class="form-control" id="experience" name="experience" placeholder="Example: 3 years">
                            </div>
                            <div class="col-md-6">
                                <label for="resume" class="form-label">Resume</label>
                                <input type="file" class="form-control" id="resume" name="Resume" accept=".pdf,.doc,.docx">
                            </div>
                            <div class="col-md-6">
                                <label for="profilePic" class="form-label">Profile picture</label>
                                <input type="file" class="form-control" id="profilePic" name="ProfilePicture" accept=".jpg,.jpeg,.png,.webp">
                            </div>
                            <div class="col-12">
                                <label for="about" class="form-label">About me</label>
                                <textarea class="form-control" id="about" rows="4" name="about" placeholder="Describe your service style, strengths, and availability."></textarea>
                            </div>
                        </div>
                        <div class="d-flex justify-content-end mt-4">
                            <button type="submit" class="btn btn-primary px-4">Submit for approval</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="app-section bg-white">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-lg-5">
                <span class="eyebrow">Provider journey</span>
                <h2 class="fw-bold mt-2">From profile to published services</h2>
                <p class="lead-muted mb-0">The provider flow is designed to protect customers while giving skilled professionals tools to manage their work.</p>
            </div>
            <div class="col-lg-7">
                <div class="row g-3">
                    <div class="col-md-4"><div class="app-card step-card lift-3d"><span class="step-number">1</span><h5 class="fw-bold mt-3">Apply</h5><p class="lead-muted mb-0">Submit your skill and profile details.</p></div></div>
                    <div class="col-md-4"><div class="app-card step-card lift-3d"><span class="step-number">2</span><h5 class="fw-bold mt-3">Approval</h5><p class="lead-muted mb-0">Admins review provider requests.</p></div></div>
                    <div class="col-md-4"><div class="app-card step-card lift-3d"><span class="step-number">3</span><h5 class="fw-bold mt-3">Manage</h5><p class="lead-muted mb-0">Publish services and track bookings.</p></div></div>
                </div>
            </div>
        </div>
    </div>
</section>
