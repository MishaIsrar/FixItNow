@{
    Layout = "_Layout1";
    ViewData["Title"] = "Sign In";
}

<section class="auth-page">
    <div class="container">
        <div class="row auth-card app-card overflow-hidden">
            <div class="col-lg-5 p-0">
                <div class="auth-side d-flex flex-column justify-content-between">
                    <div>
                        <span class="eyebrow text-white-50">Welcome Back</span>
                        <h1 class="mt-3 mb-3">Manage bookings with confidence.</h1>
                        <p class="mb-0 text-white-50">Sign in to book services, message providers, review completed work, or manage your provider dashboard.</p>
                    </div>
                    <div class="mt-4 d-grid gap-2">
                        <a class="btn btn-light" href="/Authentication/SignUp">Create customer account</a>
                        <a class="btn btn-outline-light" href="/Authentication/ProviderRegistration">Join as provider</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-7 p-0">
                <form class="auth-form" asp-action="SignIn" asp-controller="Authentication" method="post">
                    <h2 class="fw-bold mb-2">Sign in</h2>
                    <p class="lead-muted mb-4">Use the email and password connected to your FixItNow account.</p>

                    @if (!string.IsNullOrWhiteSpace(ViewBag.x))
                    {
                        <div class="alert alert-danger" role="alert">@ViewBag.x</div>
                    }

                    <div class="mb-3">
                        <label for="inputEmail3" class="form-label">Email</label>
                        <input type="email" class="form-control" id="inputEmail3" name="email" autocomplete="email" required>
                    </div>
                    <div class="mb-3">
                        <label for="inputPassword3" class="form-label">Password</label>
                        <input type="password" class="form-control" id="inputPassword3" name="password" autocomplete="current-password" required>
                    </div>
                    <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3 mt-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="gridCheck1">
                            <label class="form-check-label" for="gridCheck1">Remember me</label>
                        </div>
                        <button type="submit" class="btn btn-primary px-4">Sign in</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<section class="app-section bg-white">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4"><div class="app-card p-4 h-100 lift-3d"><h5 class="fw-bold">Customers</h5><p class="lead-muted mb-0">Access saved services, booking history, messages, and reviews.</p></div></div>
            <div class="col-md-4"><div class="app-card p-4 h-100 lift-3d"><h5 class="fw-bold">Providers</h5><p class="lead-muted mb-0">Open your dashboard to manage services, bookings, and customer questions.</p></div></div>
            <div class="col-md-4"><div class="app-card p-4 h-100 lift-3d"><h5 class="fw-bold">Admins</h5><p class="lead-muted mb-0">Review provider approvals and monitor platform activity securely.</p></div></div>
        </div>
    </div>
</section>
