@{
    Layout = "_Layout1";
    ViewData["Title"] = "All Bookings";
}
@model List<Booking>

<section class="app-section">
    <div class="container">
        <div class="app-page-header">
            <span class="eyebrow">Admin</span>
            <h1 class="fw-bold mt-2 mb-2">Bookings</h1>
            <p class="lead-muted mb-0">All service booking requests across FixItNow.</p>
        </div>
        <div class="app-card">
            <div class="card-body p-0">
                @if (Model != null && Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Customer</th>
                                    <th>Provider</th>
                                    <th>Service</th>
                                    <th>Date</th>
                                    <th>Price</th>
                                    <th>Description</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var booking in Model)
                                {
                                    <tr>
                                        <td>@booking.Id</td>
                                        <td>@booking.customerId</td>
                                        <td>@booking.providerId</td>
                                        <td>@booking.serviceId</td>
                                        <td>@booking.Date.ToString("dd MMM yyyy")</td>
                                        <td>@booking.pricing</td>
                                        <td>@(booking.description?.Length > 45 ? booking.description.Substring(0, 45) + "..." : booking.description)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state m-4">No bookings to show.</div>
                }
            </div>
        </div>
    </div>
</section>
