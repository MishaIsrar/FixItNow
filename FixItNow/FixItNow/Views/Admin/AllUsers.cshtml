@{
    Layout = "_Layout1";
    ViewData["Title"] = "All Users";
}
@model List<User>

<section class="app-section">
    <div class="container">
        <div class="app-page-header">
            <span class="eyebrow">Admin</span>
            <h1 class="fw-bold mt-2 mb-2">Users</h1>
            <p class="lead-muted mb-0">Registered customer accounts on the platform.</p>
        </div>
        <div class="app-card">
            <div class="card-body p-0">
                @if (Model != null && Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Phone</th>
                                    <th>City</th>
                                    <th>Joined</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model)
                                {
                                    <tr>
                                        <td>@user.id</td>
                                        <td>@user.firstName @user.lastName</td>
                                        <td>@user.email</td>
                                        <td>@user.phoneNumber</td>
                                        <td>@user.city</td>
                                        <td>@user.joinedTime.ToString("dd MMM yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state m-4">No users to show.</div>
                }
            </div>
        </div>
    </div>
</section>
