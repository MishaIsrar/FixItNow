@{
    Layout = "_Layout1";
    ViewData["Title"] = "Admin Panel";
}
@model FixItNow.Models.ViewModel.Admin

<section class="app-section">
    <div class="container">
        <div class="app-page-header">
            <span class="eyebrow">Admin Panel</span>
            <h1 class="fw-bold mt-2 mb-2">Platform overview</h1>
            <p class="lead-muted mb-0">Monitor users, bookings, revenue, and provider approval requests.</p>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-3 col-6">
                <div class="stat-tile">
                    <div class="text-muted">Users</div>
                    <div class="stat-value">@(Model.users?.Count ?? 0)</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-tile">
                    <div class="text-muted">Bookings</div>
                    <div class="stat-value">@(Model.bookings?.Count ?? 0)</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-tile">
                    <div class="text-muted">Revenue</div>
                    <div class="stat-value">@Model.revenue</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="stat-tile">
                    <div class="text-muted">Providers</div>
                    <div class="stat-value">@(Model.providers?.Count ?? 0)</div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="app-card mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h4 class="fw-bold mb-0">Recent users</h4>
                            <a class="btn btn-sm btn-outline-primary" href="/Admin/AllUsers">View all</a>
                        </div>
                        @if (Model.users != null && Model.users.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Email</th>
                                            <th>City</th>
                                            <th>Joined</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var user in Model.users.Take(10))
                                        {
                                            <tr>
                                                <td>@user.firstName @user.lastName</td>
                                                <td>@user.email</td>
                                                <td>@user.city</td>
                                                <td>@user.joinedTime.ToString("dd MMM yyyy")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="empty-state">No users yet.</div>
                        }
                    </div>
                </div>

                <div class="app-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h4 class="fw-bold mb-0">Recent bookings</h4>
                            <a class="btn btn-sm btn-outline-primary" href="/Admin/AllBookings">View all</a>
                        </div>
                        @if (Model.bookings != null && Model.bookings.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Booking</th>
                                            <th>Service</th>
                                            <th>Date</th>
                                            <th>Price</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var booking in Model.bookings.Take(10))
                                        {
                                            <tr>
                                                <td>@booking.Id</td>
                                                <td>@booking.serviceId</td>
                                                <td>@booking.Date.ToString("dd MMM yyyy")</td>
                                                <td>@booking.pricing</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="empty-state">No bookings yet.</div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="app-card">
                    <div class="card-body">
                        <h4 class="fw-bold mb-3">Provider approvals</h4>
                        @if (Model.providers != null && Model.providers.Any())
                        {
                            <div class="d-grid gap-3">
                                @foreach (var provider in Model.providers)
                                {
                                    <div class="p-3 border rounded">
                                        <h6 class="fw-bold mb-1">@provider.FirstName @provider.LastName</h6>
                                        <p class="lead-muted mb-3">@provider.Email</p>
                                        <div class="d-flex gap-2">
                                            <a class="btn btn-sm btn-primary" href="/Admin/Approve/@provider.Id">Approve</a>
                                            <a class="btn btn-sm btn-outline-danger" href="/Admin/Reject/@provider.Id">Reject</a>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="empty-state">No pending provider requests.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
