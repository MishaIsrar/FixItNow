@{
    Layout = "_Layout1";
    ViewData["Title"] = "Provider Profile";
}
@model FixItNow.Models.ViewModel.ProviderProfile

<section class="app-section">
    <div class="container">
        <div class="app-card p-4 p-lg-5">
            <div class="row g-4 align-items-center">
                <div class="col-lg-4 text-center">
                    <img src="/@Model.provider.ProfilePicPath" class="rounded-circle border" alt="@Model.provider.FirstName" width="220" height="220" style="object-fit: cover;">
                </div>
                <div class="col-lg-8">
                    <span class="eyebrow">Provider Profile</span>
                    <h1 class="fw-bold mt-2 mb-2">@Model.provider.FirstName @Model.provider.LastName</h1>
                    <p class="lead-muted mb-4">@Model.provider.about_me</p>
                    <div class="row g-3">
                        <div class="col-md-6"><strong>Skill:</strong> @Model.provider.skill</div>
                        <div class="col-md-6"><strong>Experience:</strong> @Model.provider.expereince</div>
                        <div class="col-md-6"><strong>Education:</strong> @Model.provider.Education</div>
                        <div class="col-md-6"><strong>City:</strong> @Model.provider.City</div>
                        <div class="col-md-6"><strong>Email:</strong> @Model.provider.Email</div>
                        <div class="col-md-6"><strong>Phone:</strong> @Model.provider.PhoneNumber</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mt-4">
            <div class="col-6 col-lg-3"><div class="stat-tile"><div class="stat-value">@Model.clients</div><div>Happy clients</div></div></div>
            <div class="col-6 col-lg-3"><div class="stat-tile"><div class="stat-value">@Model.projects</div><div>Projects completed</div></div></div>
            <div class="col-6 col-lg-3"><div class="stat-tile"><div class="stat-value">@Model.positiveReviews%</div><div>Positive reviews</div></div></div>
            <div class="col-6 col-lg-3"><div class="stat-tile"><div class="stat-value">@Model.clientSatisfaction%</div><div>Client satisfaction</div></div></div>
        </div>
    </div>
</section>
