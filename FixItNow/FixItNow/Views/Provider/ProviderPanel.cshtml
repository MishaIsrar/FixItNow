@{
    Layout = "_Layout1";
    ViewData["Title"] = "Provider Panel";
}
@model FixItNow.Models.ViewModel.ProviderPanel

<section class="app-section">
    <div class="container">
        <div class="app-page-header d-flex flex-column flex-lg-row justify-content-between gap-3">
            <div>
                <span class="eyebrow">Provider Dashboard</span>
                <h1 class="fw-bold mt-2 mb-2">Manage your services</h1>
                <p class="lead-muted mb-0">Track bookings, revenue, service performance, and customer messages.</p>
            </div>
            <div class="align-self-lg-end">
                <a class="btn btn-primary" href="/Services/AddService">Add new service</a>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="stat-tile">
                    <div class="text-muted">Total Services</div>
                    <div class="stat-value">@(Model.services?.Count ?? 0)</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-tile">
                    <div class="text-muted">Total Bookings</div>
                    <div class="stat-value">@(Model.bookings?.Count ?? 0)</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-tile">
                    <div class="text-muted">Messages</div>
                    <div class="stat-value">@(Model.messages?.Count ?? 0)</div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-lg-4"><div class="app-card p-4 h-100 lift-3d"><h5 class="fw-bold">Improve listings</h5><p class="lead-muted mb-0">Keep descriptions detailed, include clear features, and use a relevant service image.</p></div></div>
            <div class="col-lg-4"><div class="app-card p-4 h-100 lift-3d"><h5 class="fw-bold">Respond quickly</h5><p class="lead-muted mb-0">Fast message replies increase trust before customers book.</p></div></div>
            <div class="col-lg-4"><div class="app-card p-4 h-100 lift-3d"><h5 class="fw-bold">Track performance</h5><p class="lead-muted mb-0">Use bookings and revenue trends to decide which services to expand.</p></div></div>
        </div>

        <div class="app-card mb-4">
            <div class="card-body">
                <h4 class="fw-bold mb-3">Recent bookings</h4>
                @if (Model.bookings != null && Model.bookings.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Booking ID</th>
                                    <th>Title</th>
                                    <th>Date</th>
                                    <th>Price</th>
                                    <th>Customer</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.bookings.Count; i++)
                                {
                                    <tr>
                                        <td>@Model.bookings[i].Id</td>
                                        <td>@(Model.titles != null && i < Model.titles.Count ? Model.titles[i] : $"Service {Model.bookings[i].serviceId}")</td>
                                        <td>@Model.bookings[i].Date.ToString("dd MMM yyyy")</td>
                                        <td>@Model.bookings[i].pricing</td>
                                        <td>@Model.bookings[i].customerId</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">No bookings yet.</div>
                }
            </div>
        </div>

        <div class="app-card mb-4">
            <div class="card-body">
                <h4 class="fw-bold mb-3">Services</h4>
                @if (Model.services != null && Model.services.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Service</th>
                                    <th>Price</th>
                                    <th>Bookings</th>
                                    <th>Revenue</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.services.Count; i++)
                                {
                                    <tr>
                                        <td>@Model.services[i].title</td>
                                        <td>@Model.services[i].pricing</td>
                                        <td>@(Model.countOfBookings != null && i < Model.countOfBookings.Count ? Model.countOfBookings[i] : 0)</td>
                                        <td>@(Model.revenueOfServices != null && i < Model.revenueOfServices.Count ? Model.revenueOfServices[i] : 0)</td>
                                        <td class="text-end">
                                            <a class="btn btn-sm btn-outline-primary" href="/Services/Edit/@Model.services[i].id">Edit</a>
                                            <a class="btn btn-sm btn-outline-danger" href="/Services/RemoveService/@Model.services[i].id">Delete</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">Add your first service to start receiving bookings.</div>
                }
            </div>
        </div>

        <div class="app-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
                    <h4 class="fw-bold mb-0">Customer messages</h4>
                    <a href="/Message/Inbox" class="btn btn-sm btn-outline-primary">View all</a>
                </div>
                @if (Model.messages != null && Model.messages.Any())
                {
                    <div class="d-grid gap-3">
                        @foreach (var question in Model.messages.Take(5))
                        {
                            <div class="p-3 border rounded d-flex flex-column flex-lg-row justify-content-between gap-3">
                                <div>
                                    <h6 class="fw-bold mb-1">@question.title</h6>
                                    <p class="lead-muted mb-1">@(question.message?.Length > 80 ? question.message.Substring(0, 80) + "..." : question.message)</p>
                                    <small class="text-muted">@question.senderName / @question.serviceName</small>
                                </div>
                                <a class="btn btn-sm btn-primary align-self-lg-center" href="/Message/Read/@question.Id">Read</a>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">No messages yet.</div>
                }
            </div>
        </div>
    </div>
</section>
